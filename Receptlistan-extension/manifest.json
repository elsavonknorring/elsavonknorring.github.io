{
  "manifest_version": 3,
  "name": "Receptlistan 🛒",
  "version": "1.0",
  "description": "Klicka i vad du har hemma — få en inköpslista på resten.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.ica.se/*",
    "https://www.coop.se/*",
    "https://www.tasteline.com/*",
    "https://www.arla.se/*",
    "https://www.recepten.se/*",
    "https://www.koket.se/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.ica.se/*",
        "https://www.coop.se/*",
        "https://www.tasteline.com/*",
        "https://www.arla.se/*",
        "https://www.recepten.se/*",
        "https://www.koket.se/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}